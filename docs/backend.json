
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Whisper 플랫폼의 HR 전문가 프로필 정보",
      "properties": {
        "id": { "type": "string", "description": "Firebase UID" },
        "username": { "type": "string", "description": "사용자 아이디(닉네임)" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string", "description": "성함" },
        "company": { "type": "string", "description": "소속" },
        "department": { "type": "string", "description": "부서" },
        "jobTitle": { "type": "string", "description": "직함" },
        "phoneNumber": { "type": "string", "description": "휴대전화" },
        "role": { "type": "string", "enum": ["member", "mentor", "admin"], "description": "사용자 권한" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "profilePictureUrl": { "type": "string" }
      },
      "required": ["id", "username", "email", "name", "company", "department", "jobTitle", "phoneNumber", "role", "registrationDate"]
    },
    "Question": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Question",
      "type": "object",
      "description": "HR 현업 고민 및 정보 공유 게시글",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "userRole": { "type": "string" },
        "nickname": { "type": "string" },
        "category": { "type": "string" },
        "viewCount": { "type": "number" },
        "answerCount": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "content", "userId", "nickname", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "상세 HR 전문가 프로필"
        }
      },
      {
        "path": "/questions/{questionId}",
        "definition": {
          "entityName": "Question",
          "schema": { "$ref": "#/backend/entities/Question" },
          "description": "HR 고민 피드"
        }
      }
    ]
  }
}
