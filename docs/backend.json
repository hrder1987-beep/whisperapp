
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Whisper 플랫폼의 HR 전문가 상세 프로필 (본인 및 관리자 전용 보안 구역)",
      "properties": {
        "id": { "type": "string", "description": "Firebase UID" },
        "username": { "type": "string", "description": "사용자 닉네임" },
        "email": { "type": "string", "format": "email", "description": "이메일 (민감 정보, 보안 적용)" },
        "name": { "type": "string", "description": "성함 (민감 정보, 보안 적용)" },
        "company": { "type": "string", "description": "소속 회사" },
        "department": { "type": "string", "description": "소속 부서" },
        "jobTitle": { "type": "string", "description": "직함" },
        "phoneNumber": { "type": "string", "description": "휴대전화 (민감 정보, 보안 적용)" },
        "role": { "type": "string", "enum": ["member", "mentor", "admin"], "description": "사용자 권한" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "profilePictureUrl": { "type": "string" }
      },
      "required": ["id", "username", "email", "name", "company", "department", "jobTitle", "phoneNumber", "role", "registrationDate"]
    },
    "Question": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Question",
      "type": "object",
      "description": "HR 집단지성 피드 게시글 (공개)",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "userRole": { "type": "string" },
        "nickname": { "type": "string" },
        "category": { "type": "string" },
        "viewCount": { "type": "number" },
        "answerCount": { "type": "number" },
        "createdAt": { "type": "number" },
        "userProfilePicture": { "type": "string" },
        "jobTitle": { "type": "string" }
      },
      "required": ["id", "title", "text", "userId", "nickname", "createdAt"]
    },
    "Gathering": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Gathering",
      "type": "object",
      "description": "HR 전문가 모임 데이터 (공개)",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "type": { "type": "string", "enum": ["online", "offline"] },
        "location": { "type": "string" },
        "schedule": { "type": "string" },
        "capacity": { "type": "number" },
        "participantCount": { "type": "number" },
        "status": { "type": "string", "enum": ["recruiting", "in_progress", "closed"] },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "resources": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "title", "creatorId", "type", "capacity", "status", "createdAt"]
    },
    "GatheringApplication": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GatheringApplication",
      "type": "object",
      "description": "모임 참여 신청 데이터 (개인정보 포함, 접근 제한 적용)",
      "properties": {
        "id": { "type": "string" },
        "gatheringId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "appliedAt": { "type": "number" }
      },
      "required": ["gatheringId", "userId", "status", "appliedAt"]
    },
    "JobListing": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "JobListing",
      "type": "object",
      "description": "HR 전문 채용 공고 정보 (공개)",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "experience": { "type": "string" },
        "education": { "type": "string" },
        "deadline": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "logoUrl": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "companyName", "title", "location", "deadline", "createdAt"]
    },
    "PrivateMessage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PrivateMessage",
      "type": "object",
      "description": "사용자 간 1:1 개인 쪽지 (송수신자만 접근 가능)",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderNickname": { "type": "string" },
        "receiverId": { "type": "string" },
        "receiverNickname": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" },
        "isRead": { "type": "boolean" }
      },
      "required": ["senderId", "receiverId", "content", "createdAt"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "description": "사용자 알림 데이터 (본인 전용)",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["new_answer", "gathering_approved", "gathering_rejected"] },
        "questionId": { "type": "string" },
        "questionTitle": { "type": "string" },
        "senderNickname": { "type": "string" },
        "createdAt": { "type": "number" },
        "isRead": { "type": "boolean" }
      },
      "required": ["userId", "type", "questionId", "senderNickname", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "HR 전문가 개인 프로필 정보 (본인/관리자 전용 보안 구역)"
    },
    "/questions/{questionId}": {
      "schema": { "$ref": "#/entities/Question" },
      "description": "공개 HR 지식 공유 피드"
    },
    "/gatherings/{gatheringId}": {
      "schema": { "$ref": "#/entities/Gathering" },
      "description": "HR 전문가 모임 목록"
    },
    "/gatherings/{gatheringId}/applications/{appId}": {
      "schema": { "$ref": "#/entities/GatheringApplication" },
      "description": "모임 개별 신청 목록 (개인정보 보호 적용)"
    },
    "/jobs/{jobId}": {
      "schema": { "$ref": "#/entities/JobListing" },
      "description": "HR 채용 정보 데이터베이스"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/PrivateMessage" },
      "description": "1:1 개인 쪽지 데이터 (비밀 대화)"
    },
    "/notifications/{notifId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "개인 알림 센터"
    },
    "/admin_configuration/site_settings": {
      "schema": { "type": "object" },
      "description": "관리자 전용 사이트 구성 정보"
    }
  }
}
