
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WHISPER PLATFORM SECURITY RULES (SECURITY HARDENED)
     * 전문가님의 소중한 개인정보와 지적 자산을 완벽하게 보호합니다.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'forum@khrd.co.kr' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // 사용자 프로필: [보안 극대화] 
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if isOwner(userId) && request.resource.data.role == 'member';
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 질문 및 답변: 조회수(viewCount) 및 답변수(answerCount)는 비로그인 사용자도 업데이트 허용
    match /questions/{questionId} {
      allow read: if true; 
      allow create: if isSignedIn();
      
      // 핵심 수정: 업데이트 시 viewCount나 answerCount만 건드리는 경우 무조건 허용
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'answerCount'])) || 
                     (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
      
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        allow read: if true; 
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // 모임 (Gatherings): 참여자 수(participantCount) 업데이트 유연화
    match /gatherings/{gatheringId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantCount', 'status'])) || 
                     (isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin()));
      allow delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());

      match /applications/{appId} {
        allow read: if isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow delete: if isAdmin();
      }
    }

    // 1:1 개인 쪽지
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
    }

    // 알림
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 기타 공개 콘텐츠
    match /instructors/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /mentors/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /trainingPrograms/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /jobs/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /admin_configuration/{configId} { allow read: if true; allow write: if isAdmin(); }
  }
}
