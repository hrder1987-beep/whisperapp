
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WHISPER PLATFORM SECURITY RULES (SECURITY HARDENED)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'forum@khrd.co.kr' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // 질문 및 답변: 누구나 읽을 수 있지만, 작성/수정은 권한 확인
    match /questions/{questionId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        allow read: if true; 
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // 모임 (Gatherings): 공개 정보는 누구나, 신청 정보는 본인/개설자/관리자만
    match /gatherings/{gatheringId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());

      match /applications/{appId} {
        allow read: if isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow delete: if isAdmin();
      }

      match /attendance/{atId} {
        allow read: if isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow create, update: if isSignedIn() && (request.resource.data.userId == request.auth.uid);
        allow delete: if isAdmin();
      }
    }

    // 사이트 구성 정보: 누구나 읽지만 관리자만 수정
    match /admin_configuration/{configId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    // 사용자 프로필: [보안 강화] 개인정보 보호를 위해 본인과 관리자만 접근 허용
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 전문가/강사 정보: 공개 프로필이므로 누구나 조회 가능
    match /instructors/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /mentors/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /trainingPrograms/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /jobs/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 개인 쪽지: 송신자 또는 수신자만 접근 가능
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
    }

    // 알림: 본인만 접근 가능
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
