
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WHISPER PLATFORM SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      // 문서 존재 여부를 먼저 확인하여 get() 오류 방지
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member') == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    match /admin_configuration/{configId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) && (request.resource.data.get('role', 'member') == resource.data.get('role', 'member') || isAdmin());
      allow delete: if isAdmin();
    }

    match /instructors/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /mentors/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /trainingPrograms/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /jobs/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /messages/{messageId} {
      // 본인 확인 규칙을 관리자 확인보다 먼저 실행하여 불필요한 get() 호출 방지
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow read: if isAdmin();
      
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.receiverId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
    }

    match /questions/{questionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
