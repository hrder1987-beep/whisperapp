rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CHUCHOT PLATFORM SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a decentralized ownership model for an educational platform. 
     * It allows authenticated users to manage their own profiles, training programs, 
     * instructor information, and community Q&A, while keeping all content publicly 
     * readable to encourage platform growth.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Private user profile data.
     * - /instructors/{instructorId}: Profiles for educators, mapped by User UID.
     * - /trainingPrograms/{id}: Catalog of programs, linked via instructorId.
     * - /questions/{id}: Community forum for user inquiries.
     * - /questions/{id}/answers/{id}: Threaded responses to questions.
     *
     * KEY SECURITY DECISIONS:
     * 1. Public Visibility: All educational content (Programs, Instructors) and Q&A 
     *    are publicly listable to all visitors.
     * 2. Strict Ownership: Write operations (create, update, delete) are strictly 
     *    gated by the user's Auth UID.
     * 3. Relational Integrity: During creation, rules enforce that the internal 
     *    ownership field (e.g., instructorId, userId) matches the authenticated user's UID.
     * 4. Identity Consistency: For documents under /users/{userId} and /instructors/{userId}, 
     *    the document ID itself must match the user's UID.
     *
     * DENORMALIZATION FOR AUTHORIZATION:
     * To ensure high performance and avoid costly get() calls, these rules rely on 
     * 'userId' and 'instructorId' fields stored directly on programs, questions, 
     * and answers for instant authorization.
     */

    // --- HELPER FUNCTIONS ---

    /** Checks if a user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the current user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Checks ownership of an existing document. 
     * Verifies document exists and UID matches the owner field. 
     */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    /** Checks if a field remains unchanged during an update. */
    function isUnchanged(fieldName) {
      return request.resource.data[fieldName] == resource.data[fieldName];
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the UserProfile entity. Only the account owner can manage their profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid == "user_123" and userId == "user_123"
     * @deny (list) if user is not "user_123"
     * @principle Path-based ownership and self-creation enforcement.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isUnchanged('id');
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Instructor profiles. Publicly readable; only the instructor can edit.
     * @path /instructors/{instructorId}
     * @allow (get, list) if true
     * @deny (update) if auth.uid does not match instructorId
     * @principle Public access with ID-linked ownership for writes.
     */
    match /instructors/{instructorId} {
      allow get, list: if true;
      allow create: if isOwner(instructorId) && request.resource.data.id == instructorId;
      allow update: if isExistingOwner(instructorId) && isUnchanged('id');
      allow delete: if isExistingOwner(instructorId);
    }

    /**
     * @description Rules for TrainingPrograms. Publicly visible; editable only by the listed instructor.
     * @path /trainingPrograms/{programId}
     * @allow (create) if auth.uid == request.resource.data.instructorId
     * @deny (delete) if auth.uid does not match the program's instructorId
     * @principle Field-based ownership for public-read collections.
     */
    match /trainingPrograms/{programId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.instructorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.instructorId) && isUnchanged('instructorId');
      allow delete: if isExistingOwner(resource.data.instructorId);
    }

    /**
     * @description Rules for User Questions. Users can post and manage their own questions.
     * @path /questions/{questionId}
     * @allow (create) if auth.uid == request.resource.data.userId
     * @deny (update) if trying to change the userId field
     * @principle Owner-only writes with public readability.
     */
    match /questions/{questionId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && isUnchanged('userId');
      allow delete: if isExistingOwner(resource.data.userId);

      /**
       * @description Rules for Answers. Subcollection of questions.
       * @path /questions/{questionId}/answers/{answerId}
       * @allow (create) if auth.uid == request.resource.data.userId
       * @deny (delete) if user is not the author of the answer
       * @principle Subcollection protection using internal ownership fields.
       */
      match /answers/{answerId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isExistingOwner(resource.data.userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(resource.data.userId);
      }
    }
  }
}