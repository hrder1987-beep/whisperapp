
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WHISPER PLATFORM SECURITY RULES - 100% RELIABLE ACCESS
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'forum@khrd.co.kr' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // 모든 사용자가 지식 피드를 읽을 수 있도록 허용
    match /questions/{questionId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        allow read: if true; 
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // 모임 (Gatherings) 규칙
    match /gatherings/{gatheringId} {
      allow read: if true; // 누구나 모임 목록은 볼 수 있음
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());

      match /applications/{appId} {
        // 자신의 신청서 또는 모임 개설자만 읽기 가능
        allow read: if isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/gatherings/$(gatheringId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow delete: if isAdmin();
      }
    }

    // 기본 설정 및 사이트 구성 정보 (공개 읽기)
    match /admin_configuration/{configId} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    // 사용자 프로필
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 강사 및 위스퍼러 (공개 정보)
    match /instructors/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /mentors/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 교육 프로그램 및 채용 정보 (공개 정보)
    match /trainingPrograms/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /jobs/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 쪽지 시스템 - 로그인한 사용자만 접근 가능하도록 단순화
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
    }

    // 알림 시스템 - 로그인한 사용자만 자신의 알림을 읽을 수 있도록 설정
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
