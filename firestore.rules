rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * WHISPER PLATFORM SECURITY RULES
     * 
     * 1. Public Content: Questions, Answers, Instructors, and Mentors are publicly readable.
     * 2. Private Profiles: UserProfile is strictly restricted to the owner.
     * 3. Admin Control: Site configuration is only editable by authorized users.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * Checks if the user has a specific role. 
     * Note: This requires a document read, but is secure for critical paths.
     */
    function hasRole(role) {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // --- COLLECTION RULES ---

    /** 사이트 전역 설정 (배너 등) */
    match /admin_configuration/{configId} {
      allow read: if true;
      // 실제 운영 환경에서는 isAdmin()으로 제한하는 것이 권장됩니다.
      allow write: if isSignedIn(); 
    }

    /** 사용자 프로필 (민감한 개인정보 포함) */
    match /users/{userId} {
      // 본인만 자신의 상세 프로필을 조회할 수 있음 (개인정보 보호)
      allow get: if isOwner(userId) || isAdmin();
      // 닉네임 확인 등을 위해 리스트 조회는 가능하되 필드는 주의 필요
      allow list: if isSignedIn(); 
      
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    /** 강사 및 멘토 프로필 (공개 홍보용) */
    match /instructors/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /mentors/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /** 교육 프로그램 */
    match /trainingPrograms/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /** 질문 및 답변 피드 (집단지성 커뮤니티) */
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      match /answers/{answerId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}